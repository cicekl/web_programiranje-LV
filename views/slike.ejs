<!DOCTYPE html>
<html lang="hr">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Galerija slika</title>
	<link rel="stylesheet" href="/style/style_slike.css">
</head>

<body>

<header>
	<h1>Galerija</h1>
</header>

<header>
	<nav role="navigation" aria-label="Primarna navigacija">
		<ul>
			<li class="dropdown">
				<h2 id="primarna-navigacija" class="nav-toggle">Primarna navigacija</h2>
				<ul class="dropdown-content">
					<li><a href="/">Pocetna</a></li>
					<li><a href="/grafikon.html">Grafikon</a></li>
					<li><a href="/slike">Slike</a></li>
				</ul>
			</li>	
		</ul>
	</nav>
</header>

<section class="galerija" aria-label="Galerija slika"> 
	<h1>Galerija slika</h1>
	<div class="galerija_slike">

		<% images.forEach((image) => { %>
			<figure class="galerija_slika">
				<a href="#<%= image.id %>">
					<img src="<%= image.url %>" alt="<%= image.title %>">
				</a>
				<figcaption><%= image.title %></figcaption>
			</figure>

			<div id="<%= image.id %>" class="lightbox">
				<a href="#" class="close" aria-label="Zatvori sliku">×</a>
				<img src="<%= image.full %>" alt="<%= image.title %>">
			</div>
		<% }) %>

	</div>
</section>

<footer>
	<p>&copy; 2026. Web Programiranje. Sva prava pridrzana.</p>
</footer>

</body>
</html>